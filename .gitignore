cat > .gitignore << 'EOF'
# Secrets — NUNCA commitear
secrets.txt
.env
.env.local

# Datos generados (privados)
data/
*.csv
*.xlsx
*.xls

# Python
__pycache__/
*.py[cod]
*.so
.Python
build/
dist/
*.egg-info/
.eggs/

# Virtualenvs
venv/
env/
.venv/

# Editores
.vscode/
.idea/
*.swp
*~

# macOS
.DS_Store
._*
.AppleDouble
.LSOverride

# Jupyter
.ipynb_checkpoints/

# Logs
*.log
logs/

# Excepciones: SÍ subir los ejemplos
!secrets.example.txt
!tickers_ejemplo.txt
EOF